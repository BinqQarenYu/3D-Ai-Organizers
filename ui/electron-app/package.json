{
    "name": "ai-asset-memory-ui",
    "version": "1.0.0",
    "description": "AI Asset Memory Frontend",
    "main": "dist/main/main.js",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build && tsc -p tsconfig.node.json",
        "serve": "vite preview",
        "electron:start": "npm run build && electron .",
        "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"wait-on http://127.0.0.1:5173 && electron .\""
    },
    "dependencies": {
        "@react-three/drei": "^9.122.0",
        "@react-three/fiber": "^8.18.0",
        "@types/three": "^0.183.1",
        "jwt-decode": "^4.0.0",
        "lucide-react": "^0.378.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-router-dom": "^7.13.1",
        "three": "^0.183.2"
    },
    "devDependencies": {
        "@types/node": "^20.12.11",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.19",
        "concurrently": "^8.2.2",
        "cross-env": "^7.0.3",
        "electron": "^30.0.2",
        "electron-builder": "^24.13.3",
        "postcss": "^8.4.38",
        "tailwindcss": "^3.4.3",
        "tsx": "^4.21.0",
        "typescript": "^5.4.5",
        "vite": "^5.2.11",
        "wait-on": "^7.2.0"
    }
}
